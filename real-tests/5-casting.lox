fun assert(input, expected) {
    if (input != expected) {
        print "ERROR";
    } else {
        print "OK";
    }
}

print "--- TYPE CASTING ---";
assert(number true, 1);
assert(number false, 0);
assert(number "42", 42);
assert(bool false, false);
assert(bool 0, true);
assert(bool "", true);
assert(string true, "true");
assert(string nil, "nil");
assert(string 42, "42");
assert(string(number "5"), "5");
assert(number(string 3.14), 3.14);
